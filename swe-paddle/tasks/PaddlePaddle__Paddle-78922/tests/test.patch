+import gc
+import sys
+import unittest
+
+import paddle
+from paddle.distributed.flex_checkpoint.dcp.utils import (
+    flatten_state_dict,
+    unflatten_state_dict,
+)
+
+
+class TestFlattenStateDict(unittest.TestCase):
+    def test_nested_state_dict_round_trip(self):
+        weight = paddle.to_tensor([1.0, 2.0])
+        bias = paddle.to_tensor([3.0])
+
+        flat_state, mapping = flatten_state_dict(
+            {'model': {'weight': weight, 'block': {'bias': bias}}}
+        )
+
+        self.assertEqual(set(flat_state), {'model.weight', 'model.block.bias'})
+        self.assertEqual(mapping['model.weight'], ('model', 'weight'))
+        self.assertEqual(mapping['model.block.bias'], ('model', 'block', 'bias'))
+        self.assertIs(flat_state['model.weight'], weight)
+        self.assertIs(flat_state['model.block.bias'], bias)
+
+        restored = unflatten_state_dict(flat_state, mapping)
+        self.assertIs(restored['model']['weight'], weight)
+        self.assertIs(restored['model']['block']['bias'], bias)
+
+    def test_tensor_reference_released_without_cycle_gc(self):
+        gc.collect()
+        gc_was_enabled = gc.isenabled()
+        gc.disable()
+
+        try:
+            tensor = paddle.ones([1], dtype='float32')
+            baseline_refcount = sys.getrefcount(tensor)
+
+            flat_state, mapping = flatten_state_dict(
+                {'model': {'weight': tensor}}
+            )
+            self.assertEqual(sys.getrefcount(tensor), baseline_refcount + 1)
+
+            del flat_state
+            del mapping
+
+            self.assertEqual(sys.getrefcount(tensor), baseline_refcount)
+        finally:
+            if gc_was_enabled:
+                gc.enable()
+            gc.collect()
+
+
+if __name__ == '__main__':
+    unittest.main()
