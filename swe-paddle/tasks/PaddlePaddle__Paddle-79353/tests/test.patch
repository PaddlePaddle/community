+import unittest
+
+from paddle.distributed.fleet.meta_parallel.pp_utils.p2p_communication import (
+    P2pHelper,
+)
+
+
+class TestP2pOverlapBoundary(unittest.TestCase):
+    def setUp(self):
+        self.helper = P2pHelper()
+
+    def test_non_overlap_boundary_behavior(self):
+        input_tensor = self.helper.recv_forward(
+            pp_first_stage=True,
+            overlap_p2p_comm=False,
+        )
+        self.assertIsNone(input_tensor)
+
+        result = self.helper.send_backward(
+            input_tensor_grad=None,
+            pp_first_stage=True,
+            overlap_p2p_comm=False,
+        )
+        self.assertIsNone(result)
+
+    def test_recv_forward_overlap_at_first_stage(self):
+        input_tensor, wait_handles = self.helper.recv_forward(
+            pp_first_stage=True,
+            overlap_p2p_comm=True,
+        )
+
+        self.assertIsNone(input_tensor)
+        self.assertIsNone(wait_handles)
+
+    def test_send_backward_overlap_at_first_stage(self):
+        wait_handles = self.helper.send_backward(
+            input_tensor_grad=None,
+            pp_first_stage=True,
+            overlap_p2p_comm=True,
+        )
+
+        self.assertIsNone(wait_handles)
